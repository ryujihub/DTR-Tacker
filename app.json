{
  "expo": {
    "name": "dtr-tracker",
    "slug": "dtr-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/punch-clock.png",
    "scheme": "dtrtracker",
    "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/punch-clock.png",
        "backgroundImage": "./assets/images/punch-clock.png",
        "monochromeImage": "./assets/images/punch-clock.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.andreyryuji09.dtrtracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/punch-clock.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/punch-clock.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a33181e-9379-4541-9ab9-349a00361679"
      }
    }
  }
}
